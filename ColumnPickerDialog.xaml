<Window x:Class="LeakTrendViewer.ColumnPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="컬럼 선택"
        Width="350"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="전체 선택" Width="90" Height="30" Margin="0,0,8,0" Click="SelectAllButton_Click" />
            <Button Content="전체 해제" Width="90" Height="30" Click="DeselectAllButton_Click" />
        </StackPanel>

        <ListBox x:Name="ColumnListBox" Grid.Row="1" ItemsSource="{Binding Columns}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Margin="4" IsChecked="{Binding IsSelected}" Content="{Binding Name}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="확인" Width="80" Height="30" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click" />
            <Button Content="취소" Width="80" Height="30" IsCancel="True" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
