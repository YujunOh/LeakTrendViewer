<Window x:Class="LeakTrendViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="Leak Check Detect System Viewer"
        Width="1500"
        Height="900"
        MinWidth="1200"
        MinHeight="760"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Top control panel ═══ -->
        <Border Grid.Row="0"
                Padding="10"
                Background="#FFF7EDD1"
                BorderBrush="#FFCC9A00"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>

                <!-- Row 0: Data folder path -->
                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="데이터 폴더" />
                    <Button x:Name="BrowseFolderButton"
                            DockPanel.Dock="Right"
                            MinWidth="70"
                            Height="26"
                            Margin="6,0,0,0"
                            Click="BrowseFolderButton_Click"
                            Content="변경..." />
                    <TextBlock x:Name="FolderInfoLabel"
                               DockPanel.Dock="Right"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF2E7D32"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Text="" />
                    <TextBox x:Name="DataFolderTextBox"
                             Height="26"
                             VerticalContentAlignment="Center"
                             IsReadOnly="True"
                             Background="#FFFEFEFE"
                             BorderBrush="#FFBBBBBB"
                             Text="C:\B_MilliData" />
                </DockPanel>

                <!-- Row 1: Date/Time pickers + file count -->
                <WrapPanel Margin="0,0,0,6"
                           VerticalAlignment="Center"
                           ItemHeight="30">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="시작" />
                    <DatePicker x:Name="StartDatePicker"
                                Width="135"
                                Margin="0,0,8,0"
                                SelectedDateFormat="Short"
                                SelectedDateChanged="DatePicker_SelectedDateChanged" />
                    <ComboBox x:Name="StartHourCombo"
                              Width="62" />
                    <TextBlock Margin="4,0,4,0"
                               VerticalAlignment="Center"
                               Text=":" />
                    <ComboBox x:Name="StartMinuteCombo"
                              Width="62"
                              Margin="0,0,18,0" />

                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="끝" />
                    <DatePicker x:Name="EndDatePicker"
                                Width="135"
                                Margin="0,0,8,0"
                                SelectedDateFormat="Short"
                                SelectedDateChanged="DatePicker_SelectedDateChanged" />
                    <ComboBox x:Name="EndHourCombo"
                              Width="62" />
                    <TextBlock Margin="4,0,4,0"
                               VerticalAlignment="Center"
                               Text=":" />
                    <ComboBox x:Name="EndMinuteCombo"
                              Width="62"
                              Margin="0,0,12,0" />

                    <TextBlock x:Name="FileCountLabel"
                               VerticalAlignment="Center"
                               Foreground="#FF1565C0"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Text="" />
                </WrapPanel>

                <!-- Row 2: Quick date presets -->
                <WrapPanel Margin="0,0,0,6"
                           VerticalAlignment="Center">
                    <WrapPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Margin" Value="0,0,4,0" />
                            <Setter Property="Padding" Value="10,3" />
                            <Setter Property="FontSize" Value="11.5" />
                        </Style>
                    </WrapPanel.Resources>
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#FF666666"
                               Text="빠른 선택:" />
                    <Button Content="최근 1시간" Click="PresetLastHour_Click" />
                    <Button Content="오늘" Click="PresetToday_Click" />
                    <Button Content="어제" Click="PresetYesterday_Click" />
                    <Button Content="최근 3일" Click="PresetLast3Days_Click" />
                    <Button Content="최근 7일" Click="PresetLast7Days_Click" />
                    <Button Content="최근 30일" Click="PresetLast30Days_Click" />
                </WrapPanel>

                <!-- Row 3: Action buttons -->
                <WrapPanel HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <WrapPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Margin" Value="0,0,6,0" />
                            <Setter Property="MinHeight" Value="32" />
                        </Style>
                    </WrapPanel.Resources>
                    <Button x:Name="ImportFilesButton"
                            MinWidth="120"
                            Height="32"
                            Click="ImportFilesButton_Click"
                            ToolTip="MDB 파일을 직접 선택해서 불러옵니다"
                            Content="파일 불러오기" />
                    <Button x:Name="LoadButton"
                            MinWidth="110"
                            Height="32"
                            Click="LoadButton_Click"
                            Background="#FFFFBC00"
                            BorderBrush="#FF8B6A00"
                            FontWeight="SemiBold"
                            ToolTip="선택 폴더에서 날짜 기준 파일을 조회하여 그리드/차트에 표시합니다"
                            Content="자료 조회" />
                    <Button x:Name="ExcelReportButton"
                            MinWidth="140"
                            Height="32"
                            Click="ExcelReportButton_Click"
                            Background="#FF4CAF50"
                            BorderBrush="#FF2E7D32"
                            Foreground="White"
                            FontWeight="Bold"
                            ToolTip="선택 날짜 범위의 MDB → Excel(데이터+차트) 바로 생성 후 열기"
                            Content="Excel Report" />
                    <Button x:Name="SyncButton"
                            MinWidth="100"
                            Height="32"
                            Click="SyncButton_Click"
                            ToolTip="그리드 선택 범위에 맞춰 차트 구간을 맞춥니다"
                            Content="차트 동기화" />
                    <Button x:Name="ColumnPickerButton"
                            MinWidth="100"
                            Height="32"
                            Click="ColumnPickerButton_Click"
                            ToolTip="표시할 컬럼을 선택합니다"
                            Content="컬럼 선택" />
                    <Button x:Name="ExportButton"
                            MinWidth="100"
                            Height="32"
                            Click="ExportButton_Click"
                            Content="CSV 내보내기" />
                    <Button x:Name="ExportExcelButton"
                            MinWidth="110"
                            Height="32"
                            Margin="0"
                            Click="ExportExcelButton_Click"
                            Content="Excel 내보내기" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Data area: Grid + Chart ═══ -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.65*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    BorderBrush="#FF31607A"
                    BorderThickness="1"
                    CornerRadius="4">
                <DataGrid x:Name="LeakGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionChanged="LeakGrid_SelectionChanged"
                          HeadersVisibility="Column"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True" />
            </Border>

            <Border Grid.Column="1"
                    Margin="8,0,0,0"
                    BorderBrush="#FF31607A"
                    BorderThickness="1"
                    CornerRadius="4">
                <oxy:PlotView x:Name="TrendPlotView" MouseDown="TrendPlotView_MouseDown" />
            </Border>
        </Grid>

        <!-- ═══ Status bar ═══ -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="준비됨" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
